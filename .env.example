# ─── Discord Music API Configuration ─────────────────────────────────────────

# HTTP port the API listens on
PORT=5000

# Environment: development | production
NODE_ENV=development

# API Key — must be at least 16 characters. Set this to a strong random string.
# Example: openssl rand -hex 32
API_KEY=your-super-secret-api-key-here

# Your Discord bot's User ID (required by Lavalink handshake)
DISCORD_BOT_USER_ID=1234567890123456789

# Name shown to Lavalink (optional)
CLIENT_NAME=discord-music-api/1.0

# ─── Lavalink Node ────────────────────────────────────────────────────────────

LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
# Set to true if Lavalink is behind HTTPS/WSS
LAVALINK_SECURE=false

# Reconnect settings
LAVALINK_RECONNECT_INTERVAL=5000
# 0 = infinite retries
LAVALINK_RECONNECT_MAX_RETRIES=0

# ─── Cache ────────────────────────────────────────────────────────────────────

# Seconds to cache search results
CACHE_TTL=300
# Maximum number of cached entries
CACHE_MAX_KEYS=500

# ─── Rate Limiting ────────────────────────────────────────────────────────────

# Window in milliseconds
RATE_LIMIT_WINDOW_MS=60000
# Maximum requests per window per IP
RATE_LIMIT_MAX=100
